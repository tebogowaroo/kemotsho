{
  "name": "kemotsho",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=@kemotsho/web",
    "lint": "npm run lint --workspaces",
    "start": "npm run start --workspace=web"
  },
  "devDependencies": {
    "@types/react-google-recaptcha": "^2.1.9",
    "tailwindcss-animate": "^1.0.7"
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.8.0",
    "stripe": "^20.3.1"
  }
}